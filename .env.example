# ── Fantasy Points System — Environment Variables ─────────────────────────────
#
# Copy this file to .env and fill in the values.
# The .env file is gitignored and must never be committed.

# Google Sheets spreadsheet ID (from the sheet URL)
SPREADSHEET_ID=1VP_iSR_LoJRyyGWENSuc8gKz1YbphD0htKd-w66mvFI

# Worksheet (tab) name inside the spreadsheet
WORKSHEET_NAME=IPL_2026_Auction_List

# Backend server port
BACKEND_PORT=8080

# Set to "false" to see the browser during scraping (debugging)
BROWSER_HEADLESS=true
